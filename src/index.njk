---
layout: layouts/base.njk
title: All-in-one solution for managing your cocktail bar · Bar Assistant
description: Track your bar inventory, organize cocktail recipes, and create custom menus. Free for home use. Used by 900+ aspiring bartenders.
showFullNav: true
analytics: true
lang: en
---

{% include "components/hero.njk" %}
<div class="in-page-title">
    <div class="in-page-title__content">
        <h3>{{ i18n[lang].sections.main_features }}</h3>
        <p>{{ i18n[lang].sections.main_features_subtitle }}</p>
    </div>
</div>
<div class="main-features">
    {% include "components/bigFeature.njk" %}
</div>
<div class="in-page-title">
    <div class="in-page-title__content">
        <h3>{{ i18n[lang].sections.more_features }}</h3>
        <p>{{ i18n[lang].sections.more_features_subtitle }}</p>
    </div>
</div>
<div class="features">
    {% include "components/feature.njk" %}
</div>
<div class="in-page-title">
    <div class="in-page-title__content">
        <h3>{{ i18n[lang].sections.choose_plan }}</h3>
        <p>{{ i18n[lang].sections.choose_plan_subtitle }}</p>
    </div>
</div>
<div class="plans">
    {% for plan in plans[lang] %}
    <div class="plans__plan {{ plan.cssClass }}">
        {% if plan.price %}
        <h2>{{ plan.name }}</h2>
        <div class="plans__plan__price">
            <h4>{{ plan.price | safe }}</h4>
            <small>{{ plan.billing }}</small>
        </div>
        {% else %}
        <h3>{{ plan.name }}</h3>
        {% endif %}
        <p>{{ plan.description }}</p>
        <ul>
            {% for feature in plan.features %}
            <li>{{ feature | safe }}</li>
            {% endfor %}
        </ul>
        {% if plan.ctaText %}
        <div class="plans__plan__action">
            <a href="{{ plan.ctaLink }}" class="button {{ plan.ctaClass }}">{{ plan.ctaText }}</a>
        </div>
        {% elif plan.links %}
        <div>
            {% for link in plan.links %}
            <a href="{{ link.url }}">{{ link.text }}</a>{% if not loop.last %} &middot; {% endif %}
            {% endfor %}
        </div>
        {% endif %}
    </div>
    {% endfor %}
</div>
<div class="in-page-title">
    <div class="in-page-title__content">
        <h3>{{ i18n[lang].sections.faq }}</h3>
        <p>{{ i18n[lang].sections.faq_subtitle }}</p>
    </div>
</div>
<div class="page-faq" itemscope itemtype="https://schema.org/FAQPage">
    {% for item in faq[lang] %}
    <div class="faq__question" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <h5 itemprop="name">{{ item.question }}</h5>
        <p itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
            <span itemprop="text">{{ item.answer | safe }}</span>
        </p>
    </div>
    {% endfor %}
</div>
